generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hashed with bcrypt
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                   String                @id @default(cuid())
  username             String                @unique // Common display name / reference
  instagram            String? // Handle
  tiktok               String? // Handle
  twitter              String? // Handle
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  snapshots            Snapshot[]
  categories           AccountCategory[]
  individualReportRuns IndividualReportRun[]
}

// Join table for many-to-many Account <-> Category relationship
model AccountCategory {
  accountId  String
  categoryId String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([accountId, categoryId])
  @@index([categoryId])
}

model Snapshot {
  id         String         @id @default(cuid())
  accountId  String
  account    Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform   Platform // Which platform this snapshot is for
  followers  Int
  following  Int?
  posts      Int?
  engagement Float?
  likes      Int? // TikTok totalLikes (heartCount)
  scrapedAt  DateTime       @default(now())
  source     SnapshotSource @default(SCRAPED)
  sourceNote String?
  jobId      String?
  job        ScrapingJob?   @relation(fields: [jobId], references: [id])

  @@index([accountId])
  @@index([scrapedAt])
  @@index([jobId])
  @@index([platform])
}

model ScrapingJob {
  id                  String     @id @default(cuid())
  status              JobStatus  @default(PENDING)
  totalAccounts       Int
  completedCount      Int        @default(0)
  failedCount         Int        @default(0)
  errors              Json? // Array of { accountId, error, platform }
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime   @default(now())
  reportingYear       Int?
  reportingMonth      Int?
  reportingReason     String?
  reportingAssignedAt DateTime?
  snapshots           Snapshot[]

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([reportingYear, reportingMonth])
  @@index([status])
  @@index([createdAt])
  @@index([categoryId])
  @@index([reportingYear, reportingMonth])
}

model Category {
  id        String            @id @default(cuid())
  name      String            @unique
  accounts  AccountCategory[]
  jobs      ScrapingJob[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model IndividualReportRun {
  id                String                 @id @default(cuid())
  accountId         String
  account           Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  year              Int
  quarter           Int
  status            IndividualReportStatus @default(PARTIAL)
  estimatedCredits  Int
  actualCreditsUsed Int
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  platformResults IndividualReportPlatformResult[]

  @@index([accountId])
  @@index([year, quarter])
  @@index([createdAt])
}

model IndividualReportPlatformResult {
  id          String                         @id @default(cuid())
  runId       String
  run         IndividualReportRun            @relation(fields: [runId], references: [id], onDelete: Cascade)
  platform    Platform
  handle      String
  status      IndividualReportPlatformStatus
  creditsUsed Int                            @default(0)
  resultJson  Json?
  error       String?
  scrapedAt   DateTime?
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt

  @@unique([runId, platform])
  @@index([platform])
  @@index([status])
}

enum Platform {
  INSTAGRAM
  TIKTOK
  TWITTER
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum IndividualReportStatus {
  COMPLETE
  PARTIAL
  FAILED
}

enum IndividualReportPlatformStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SnapshotSource {
  SCRAPED
  MANUAL
}

model Settings {
  id           String   @id @default("app") // Singleton
  cronSchedule String   @default("0 0 * * *") // Daily at midnight UTC
  updatedAt    DateTime @updatedAt
}
